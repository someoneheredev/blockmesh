{
  "name": "blockmesh",
  "version": "1.1.0",
  "description": "Host Minecraft with your friends",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "package": "electron-builder --win --x64",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.blockmesh.app",
    "productName": "BlockMesh",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/**/*",
      "backend/**/*",
      "!backend/__pycache__",
      "!backend/**/__pycache__"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "asar": true,
    "asarUnpack": [
      "**/assets/**"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  }
}
